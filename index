.m-name{font-size:13px;font-weight:700;color:var(--txt)}
.m-goal{font-size:11px;color:var(--t2);margin-top:2px}
.m-tags{display:flex;gap:5px;margin-top:5px}
.tag{font-size:10px;font-weight:600;padding:2px 8px;border-radius:99px}
