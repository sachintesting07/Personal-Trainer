.trend-up{color:var(--grn)}
.trend-dn{color:var(--red)}
.chart-card{background:var(--s1);border:1px solid var(--bdr);border-radius:16px;padding:15px;margin:0 22px 14px}
.chart-title{font-size:13px;font-weight:700;color:var(--txt);margin-bottom:12px}
.chart-subtitle{font-size:11px;color:var(--t2);margin-bottom:10px}
