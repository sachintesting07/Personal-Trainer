<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>FitCore — Gym Owner App</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#08080F;--s1:#0D0D1A;--s2:#12121F;--s3:#1A1A2C;--s4:#22223A;
  --p:#7B5CFF;--p2:#9B8FF8;--p3:#5A3FD4;
  --red:#EF5050;--redbg:rgba(239,80,80,.1);--redbd:rgba(239,80,80,.28);
  --amb:#E8A020;--ambbg:rgba(232,160,32,.1);--ambbd:rgba(232,160,32,.28);
  --blu:#4898F8;--blubg:rgba(72,152,248,.1);--blubd:rgba(72,152,248,.28);
  --grn:#20C878;--grnbg:rgba(32,200,120,.1);--grnbd:rgba(32,200,120,.28);
  --txt:#F0F0FA;--t2:#8080A8;--t3:#45455E;
  --bdr:rgba(255,255,255,.07);--bdr2:rgba(255,255,255,.12);
}
body{background:#111;display:flex;justify-content:center;align-items:flex-start;min-height:100vh;padding:20px;font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased}
.phone-shell{width:390px;background:var(--bg);border-radius:44px;overflow:hidden;border:1.5px solid rgba(255,255,255,.09);box-shadow:0 40px 80px rgba(0,0,0,.8);position:relative;height:820px}

/* ── SCREENS ── */
.screen{position:absolute;inset:0;display:flex;flex-direction:column;background:var(--bg);transition:transform .32s cubic-bezier(.4,0,.2,1),opacity .32s;will-change:transform}
.screen.right{transform:translateX(100%)}
.screen.left{transform:translateX(-28%);opacity:.5}
.screen.active{transform:translateX(0);opacity:1}
.scr-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding-bottom:90px}
.scr-scroll::-webkit-scrollbar{display:none}

/* ── STATUS BAR ── */
.sb{padding:14px 22px 4px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
.sb-t{font-size:15px;font-weight:700;color:var(--txt)}
.sb-r{display:flex;align-items:center;gap:6px;color:var(--txt)}

/* ── BOTTOM NAV ── */
.bnav{background:var(--s1);border:1px solid var(--bdr2);border-radius:24px;margin:0 16px 16px;padding:9px 4px;display:flex;align-items:center;flex-shrink:0}
.ni{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;padding:3px 0;border:none;background:transparent;font-family:'Inter',sans-serif}
.ni-ico{width:38px;height:24px;display:flex;align-items:center;justify-content:center;border-radius:99px}
.ni-ico svg{width:19px;height:19px;color:var(--t3);transition:color .2s}
.ni-lbl{font-size:9px;color:var(--t3);font-weight:500;transition:color .2s}
.ni-bar{width:18px;height:3px;border-radius:2px;background:transparent;margin-top:1px;transition:background .2s}
.ni.on .ni-ico svg{color:var(--p2)}
.ni.on .ni-lbl{color:var(--p2);font-weight:700}
.ni.on .ni-bar{background:var(--p2)}

/* ── PAGE HEADERS ── */
.page-hdr{padding:10px 22px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.page-title{font-size:21px;font-weight:800;color:var(--txt);letter-spacing:-.3px}
.back-btn{width:34px;height:34px;border-radius:10px;background:var(--s2);border:1px solid var(--bdr2);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0}
.back-btn svg{width:14px;height:14px;color:#C0C0E0;stroke:#C0C0E0}

/* ── COMMON BUTTONS ── */
.btn-primary{background:linear-gradient(90deg,#7B5CFF,#5A3FD4);border:none;border-radius:99px;padding:11px 20px;color:#ffffff;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;white-space:nowrap;box-shadow:0 4px 18px rgba(100,80,230,.4);transition:opacity .2s;font-family:'Inter',sans-serif}
.btn-primary:hover{opacity:.9}
.btn-primary svg{width:14px;height:14px;color:#fff;stroke:#fff}
.btn-p{width:100%;margin-top:14px;padding:13px;border-radius:12px;background:linear-gradient(135deg,#7B5CFF,#5A3FD4);color:#ffffff;font-family:'Inter',sans-serif;font-size:14px;font-weight:700;border:none;cursor:pointer;box-shadow:0 4px 16px rgba(100,80,230,.3);transition:opacity .2s}
.btn-p:hover{opacity:.9}
.btn-g{width:100%;margin-top:8px;padding:12px;border-radius:10px;background:transparent;color:#9090B8;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;border:1px solid var(--bdr);cursor:pointer;transition:all .15s}
.btn-g:hover{border-color:var(--bdr2);color:#C0C0E0}
.btn-danger{width:100%;padding:12px;border-radius:12px;background:rgba(239,80,80,.07);border:1px solid rgba(239,80,80,.18);color:#EF5050;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;margin-bottom:8px;transition:background .2s}
.btn-danger:hover{background:rgba(239,80,80,.13)}
.btn-danger svg{width:14px;height:14px;color:#EF5050;stroke:#EF5050}

/* ── CARDS ── */
.card{background:var(--s1);border:1px solid var(--bdr);border-radius:16px;padding:16px;margin-bottom:10px}
.card2{background:var(--s1);border:1px solid var(--bdr2);border-radius:18px;padding:18px;margin-bottom:10px}

/* ── INSIGHT CARDS ── */
.igrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;padding:0 22px;margin-bottom:16px}
.ic{border-radius:15px;padding:14px 11px 14px 13px;display:flex;align-items:center;gap:11px;cursor:pointer;transition:transform .15s;position:relative}
.ic:active{transform:scale(.97)}
.ic.red{background:linear-gradient(145deg,#180909,#110606);border:1px solid var(--redbd)}
.ic.amb{background:linear-gradient(145deg,#160F04,#110C03);border:1px solid var(--ambbd)}
.ic.blu{background:linear-gradient(145deg,#060C1A,#040913);border:1px solid var(--blubd)}
.ic.grn{background:linear-gradient(145deg,#040E08,#030B06);border:1px solid var(--grnbd)}
.ic-icon{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ic-icon svg{width:22px;height:22px}
.ic.red .ic-icon{background:rgba(239,80,80,.15)}
.ic.amb .ic-icon{background:rgba(232,160,32,.15)}
.ic.blu .ic-icon{background:rgba(72,152,248,.15)}
.ic.grn .ic-icon{background:rgba(32,200,120,.15)}
.ic-body{flex:1;min-width:0}
.ic-num{font-size:28px;font-weight:900;line-height:1;letter-spacing:-1px}
.ic.red .ic-num{color:var(--red)}
.ic.amb .ic-num{color:var(--amb)}
.ic.blu .ic-num{color:var(--blu)}
.ic.grn .ic-num{color:var(--grn)}
.ic-label{font-size:12px;font-weight:700;color:#D0D0F0;margin-top:3px}
.ic-sub{font-size:10px;color:var(--t3);margin-top:2px;line-height:1.3}
.ic-chev svg{width:12px;height:12px;color:var(--t3)}

/* ── CAPACITY DONUT ── */
.cap-card{background:var(--s1);border:1px solid var(--bdr2);border-radius:20px;padding:17px;margin:0 22px 16px}
.cap-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.cap-title{font-size:15px;font-weight:800;color:var(--txt)}
.period-pill{background:rgba(255,255,255,.06);border:1px solid var(--bdr2);border-radius:99px;padding:6px 12px;font-size:11px;color:#9090B8;display:flex;align-items:center;gap:4px;cursor:pointer;font-family:'Inter',sans-serif}
.period-pill svg{width:9px;height:9px;color:#9090B8;stroke:#9090B8}
.cap-body{display:flex;align-items:center;justify-content:space-between;gap:4px}
.cap-stat{text-align:center;width:72px;flex-shrink:0}
.cs-dot-row{display:flex;align-items:center;justify-content:center;gap:5px;margin-bottom:5px}
.cs-dot{width:7px;height:7px;border-radius:50%}
.cs-label{font-size:11px;color:var(--t2);font-weight:500}
.cs-num{font-size:28px;font-weight:900;line-height:1;letter-spacing:-1px}
.cs-pct{font-size:11px;color:var(--t3);margin-top:3px}
.cap-dash{flex:1;border-top:1.5px dashed rgba(255,255,255,.09);align-self:center}
.donut-wrap{width:150px;height:150px;flex-shrink:0;position:relative}
.donut-wrap canvas{position:absolute;inset:0}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none}
.dc-ico{width:22px;height:22px;background:rgba(255,255,255,.05);border-radius:6px;display:flex;align-items:center;justify-content:center;margin-bottom:3px}
.dc-ico svg{width:12px;height:12px;color:#55557A}
.dc-lbl{font-size:9px;color:#50507A;text-transform:uppercase;letter-spacing:.6px;font-weight:600}
.dc-num{font-size:24px;font-weight:900;color:var(--txt);line-height:1.1;letter-spacing:-1px}
.live-row{display:flex;align-items:center;justify-content:center;gap:6px;margin-top:12px}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--grn);animation:lp 1.6s infinite}
@keyframes lp{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(32,200,120,.5)}60%{opacity:.5;box-shadow:0 0 0 5px rgba(32,200,120,0)}}
.live-txt{font-size:11px;color:var(--t2);font-weight:500}

/* ── SECTION HEADERS ── */
.sec-hdr{padding:0 22px 10px;display:flex;align-items:center;justify-content:space-between}
.sec-title{font-size:14px;font-weight:700;color:var(--txt)}
.sec-link{font-size:12px;color:var(--p2);cursor:pointer;font-weight:500;border:none;background:transparent;font-family:'Inter',sans-serif}

/* ── ALERT ROWS ── */
.alert-item{background:var(--s1);border:1px solid var(--bdr);border-radius:13px;padding:12px 14px;margin:0 22px 7px;display:flex;align-items:center;gap:11px;cursor:pointer;transition:all .2s}
.alert-item:hover{border-color:var(--bdr2);transform:translateX(2px)}
.a-ico{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.a-ico svg{width:16px;height:16px}
.a-body{flex:1;min-width:0}
.a-name{font-size:13px;font-weight:600;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.a-sub{font-size:11px;color:var(--t2);margin-top:1px}
.a-badge{font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px;flex-shrink:0}

/* ── MEMBER CARDS ── */
.m-card{background:var(--s1);border:1px solid var(--bdr);border-radius:14px;padding:12px 13px;margin-bottom:7px;display:flex;align-items:center;gap:11px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.m-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:3px 0 0 3px;opacity:0;transition:opacity .2s}
.m-card:hover{border-color:var(--bdr2);transform:translateX(2px)}
.m-card:hover::before{opacity:1}
.m-card.s-inactive::before{background:var(--red)}
.m-card.s-active::before{background:var(--grn)}
.m-card.s-renewal::before{background:var(--amb)}
.m-av{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;flex-shrink:0;border:2px solid transparent}
