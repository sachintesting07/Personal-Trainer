.np-body{flex:1}
.np-t{font-size:12px;font-weight:600;color:var(--txt)}
.np-s{font-size:10px;color:var(--t2);margin-top:1px}
.plan-banner{background:linear-gradient(135deg,#130E38,#0D0A24);border:1px solid rgba(123,92,255,.22);border-radius:15px;padding:15px;margin:0 22px 8px;position:relative;overflow:hidden}
.plan-banner::after{content:'';position:absolute;top:-24px;right:-24px;width:80px;height:80px;border-radius:50%;background:rgba(123,92,255,.07);pointer-events:none}
