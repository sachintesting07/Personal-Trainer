.bar-chart{display:flex;align-items:flex-end;gap:5px;height:90px}
.bar-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px}
.bar-fill{width:100%;border-radius:4px 4px 0 0;transition:height .5s;min-height:4px}
.bar-x{font-size:9px;color:var(--t3)}
.bar-val{font-size:9px;color:var(--t2);font-weight:600}
/* LINE CHART */
.line-chart-wrap{position:relative;height:90px;margin-bottom:6px}
/* HEATMAP */
.hm-outer{overflow-x:auto;scrollbar-width:none}
.hm-outer::-webkit-scrollbar{display:none}
.hm-grid{display:grid;gap:3px}
.hm-row{display:flex;gap:3px;align-items:center}
.hm-lbl{font-size:9px;color:var(--t3);width:24px;flex-shrink:0}
.hm-cell{width:18px;height:18px;border-radius:3px;flex-shrink:0}
.hm-0{background:var(--s3)}
.hm-1{background:rgba(74,152,248,.22)}
.hm-2{background:rgba(74,152,248,.44)}
.hm-3{background:rgba(74,152,248,.66)}
.hm-4{background:#4898F8}
/* DONUT SMALL */
.mini-donut-row{display:flex;align-items:center;gap:16px}
.mini-legend{flex:1}
.mini-leg-item{margin-bottom:9px}
.mini-leg-row{display:flex;justify-content:space-between;margin-bottom:3px}
.mini-leg-label{font-size:11px;color:var(--t2);display:flex;align-items:center;gap:5px}
.mini-leg-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.mini-leg-val{font-size:11px;font-weight:700}
