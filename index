.ph-mi-ico svg{width:10px;height:10px;color:var(--t2)}
.ph-mi-v{font-size:10px;font-weight:700;color:var(--txt)}
.ph-mi-l{font-size:8px;color:var(--t3);margin-top:1px;text-transform:uppercase;letter-spacing:.3px}
.action-row{display:flex;gap:8px;margin-bottom:10px}
.act-btn{flex:1;padding:10px;border-radius:11px;border:none;display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;font-family:'Inter',sans-serif;font-size:11px;font-weight:600;transition:opacity .2s}
.act-btn:hover{opacity:.8}
.act-btn svg{width:18px;height:18px}
.act-btn.call{background:rgba(32,200,120,.12);color:#20C878}
.act-btn.call svg{color:#20C878;stroke:#20C878}
.act-btn.wa{background:rgba(37,211,102,.12);color:#25D366}
.act-btn.wa svg{color:#25D366;stroke:#25D366}
.act-btn.note{background:rgba(72,152,248,.12);color:#4898F8}
.act-btn.note svg{color:#4898F8;stroke:#4898F8}
.detail-card{background:var(--s1);border:1px solid var(--bdr);border-radius:15px;padding:13px;margin-bottom:9px}
.dc-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:11px}
.dc-title{font-size:13px;font-weight:700;color:var(--txt);display:flex;align-items:center;gap:6px}
.dc-title-ico{width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center}
