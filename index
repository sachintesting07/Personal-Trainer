.modal-close svg{width:11px;height:11px;color:#C0C0E0;stroke:#C0C0E0}
.modal-scroll{flex:1;overflow-y:auto;padding:0 20px 28px;scrollbar-width:none}
.modal-scroll::-webkit-scrollbar{display:none}
.fl{font-size:11px;font-weight:600;color:#9090B8;text-transform:uppercase;letter-spacing:.5px;margin:12px 0 5px;display:block}
.fi{width:100%;background:var(--s2);border:1px solid var(--bdr2);border-radius:9px;padding:10px 12px;color:var(--txt);font-family:'Inter',sans-serif;font-size:13px;outline:none;transition:border .15s;-webkit-appearance:none}
