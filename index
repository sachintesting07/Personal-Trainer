.ver-txt{text-align:center;padding:8px 22px;font-size:11px;color:var(--t3)}

/* ── MODAL ── */
.modal-overlay{position:absolute;inset:0;background:rgba(0,0,0,.76);z-index:80;display:flex;flex-direction:column;justify-content:flex-end;backdrop-filter:blur(6px);transition:opacity .3s}
.modal-overlay.hidden{opacity:0;pointer-events:none}
.modal{background:var(--s1);border-radius:22px 22px 0 0;border-top:1px solid var(--bdr2);max-height:90%;display:flex;flex-direction:column;transition:transform .32s cubic-bezier(.4,0,.2,1)}
