.opp-body{flex:1;min-width:0}
.opp-name{font-size:13px;font-weight:600;color:var(--txt)}
.opp-sub{font-size:11px;color:var(--t2);margin-top:1px}
.opp-val{font-size:13px;font-weight:800;color:var(--p2);flex-shrink:0}

/* ── SETTINGS ── */
.sg{background:var(--s1);border:1px solid var(--bdr);border-radius:14px;overflow:hidden;margin:0 22px 8px}
.sr{display:flex;align-items:center;gap:11px;padding:12px 14px;border-bottom:1px solid var(--bdr);cursor:pointer;transition:background .15s}
