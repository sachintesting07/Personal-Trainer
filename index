.supp-row{display:flex;align-items:center;gap:8px;margin-top:10px;padding:10px 12px;background:var(--s2);border-radius:9px;border:1px solid var(--bdr)}
.supp-row input{accent-color:var(--p);width:15px;height:15px}
.supp-row label{font-size:12px;color:#9090B8;cursor:pointer}
.step-ind{display:flex;align-items:center;margin-bottom:18px}
.si-node{display:flex;flex-direction:column;align-items:center;width:48px;flex-shrink:0}
.si-c{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;border:1.5px solid var(--bdr2);color:#7070A0;transition:all .25s;z-index:1;position:relative}
.si-c.done{background:var(--grn);border-color:var(--grn);color:#fff}
.si-c.act{background:var(--p);border-color:var(--p);color:#fff}
.si-lbl{font-size:8px;color:#55557A;margin-top:3px;text-align:center;font-weight:500}
.si-lbl.act{color:var(--p2)}
.si-line{flex:1;height:1.5px;background:var(--bdr2);margin-top:-13px;transition:background .25s}
.si-line.done{background:var(--grn)}
.confirm-box{background:rgba(123,92,255,.06);border:1px solid rgba(123,92,255,.17);border-radius:14px;padding:13px;margin-bottom:10px}
.cf-av{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--p3),var(--p));display:flex;align-items:center;justify-content:center;font-weight:900;font-size:13px;color:#fff}
.cr{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.cr:last-child{border-bottom:none}
.ck{font-size:12px;color:var(--t2)}
.cv{font-size:12px;font-weight:600;color:var(--txt)}
.trow{display:flex;align-items:center;justify-content:space-between;margin-top:12px;padding:11px 12px;background:var(--s2);border-radius:10px;border:1px solid var(--bdr)}
.trow-t{font-size:13px;font-weight:600;color:var(--txt)}
.trow-s{font-size:11px;color:var(--t2);margin-top:2px}
.info-box{background:rgba(72,152,248,.06);border:1px solid rgba(72,152,248,.14);border-radius:9px;padding:10px 12px;margin-top:10px;display:flex;gap:8px;align-items:flex-start}
.info-box svg{width:14px;height:14px;flex-shrink:0;margin-top:1px;color:#4898F8;stroke:#4898F8}
.info-box span{font-size:11px;color:var(--t2);line-height:1.5}

/* ── NOTIF PANEL ── */
.notif-panel{position:absolute;inset:0;z-index:90;background:rgba(0,0,0,.75);backdrop-filter:blur(5px);transition:opacity .25s}
.notif-panel.hidden{opacity:0;pointer-events:none}
.notif-drawer{position:absolute;top:0;right:0;width:290px;height:100%;background:var(--s1);border-left:1px solid var(--bdr2);transition:transform .3s cubic-bezier(.4,0,.2,1);overflow-y:auto;scrollbar-width:none}
.notif-drawer::-webkit-scrollbar{display:none}
.notif-drawer.hidden{transform:translateX(100%)}
.notif-hdr{padding:50px 15px 13px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between}
.notif-hdr-title{font-size:15px;font-weight:800;color:var(--txt)}
.notif-mark-btn{font-size:11px;color:var(--p2);cursor:pointer;border:none;background:transparent;font-family:'Inter',sans-serif;font-weight:600}
.notif-item{padding:12px 15px;border-bottom:1px solid var(--bdr);display:flex;gap:10px;align-items:flex-start}
.notif-ico{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.notif-ico svg{width:15px;height:15px}
.notif-text{font-size:12px;font-weight:500;color:var(--txt);line-height:1.4}
.notif-time{font-size:10px;color:var(--t3);margin-top:2px}

/* ── TOAST ── */
.toast{position:absolute;bottom:100px;left:50%;transform:translateX(-50%);background:var(--grn);color:#fff;font-size:12px;font-weight:700;padding:10px 20px;border-radius:99px;z-index:200;white-space:nowrap;box-shadow:0 4px 16px rgba(32,200,120,.4);animation:fadeUp .3s ease;font-family:'Inter',sans-serif;pointer-events:none}
@keyframes fadeUp{from{opacity:0;transform:translateX(-50%) translateY(10px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
</style>
