.tag.inactive{background:var(--redbg);color:var(--red);border:1px solid var(--redbd)}
.tag.renewal{background:var(--ambbg);color:var(--amb);border:1px solid var(--ambbd)}
.call-btn{background:linear-gradient(135deg,#7B5CFF,#5A3FD4);border:none;border-radius:9px;padding:8px 12px;color:#ffffff;font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:4px;flex-shrink:0;box-shadow:0 3px 10px rgba(100,80,230,.3);font-family:'Inter',sans-serif}
.call-btn svg{width:11px;height:11px;color:#fff;stroke:#fff}
.more-btn{width:27px;height:27px;border-radius:7px;background:var(--s3);border:none;display:flex;align-items:center;justify-content:center;cursor:pointer;margin-left:4px;flex-shrink:0}
.more-btn svg{width:13px;height:13px;color:#9090B8}

/* ── SEARCH & FILTERS ── */
.search-bar{background:var(--s2);border:1px solid var(--bdr2);border-radius:12px;padding:10px 13px;display:flex;align-items:center;gap:8px;margin:0 22px 9px}
.search-bar svg{width:14px;height:14px;color:var(--t3);flex-shrink:0}
.search-bar input{background:none;border:none;color:var(--txt);font-family:'Inter',sans-serif;font-size:13px;outline:none;flex:1}
.search-bar input::placeholder{color:var(--t3)}
.filter-chips{display:flex;gap:6px;padding:0 22px 10px;overflow-x:auto;scrollbar-width:none}
.filter-chips::-webkit-scrollbar{display:none}
.fchip{padding:5px 12px;border-radius:99px;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;border:1px solid var(--bdr);background:var(--s2);color:#9090B8;transition:all .15s;flex-shrink:0;font-family:'Inter',sans-serif}
.fchip.on{background:rgba(123,92,255,.14);border-color:rgba(123,92,255,.38);color:#B8AEFF}

/* ── MEMBER DETAIL ── */
.profile-hero{background:var(--s1);border:1px solid var(--bdr2);border-radius:18px;padding:16px;margin-bottom:10px}
.ph-top{display:flex;gap:12px;align-items:flex-start;margin-bottom:12px}
.ph-av{width:62px;height:62px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:900;flex-shrink:0;border:3px solid rgba(123,92,255,.3)}
.ph-name{font-size:17px;font-weight:800;color:var(--txt);display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.ph-vbadge{width:16px;height:16px;border-radius:50%;background:linear-gradient(135deg,#4A90E2,#7B5CFF);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ph-vbadge svg{width:8px;height:8px}
