.tog.off{background:var(--s4)}
.tth{position:absolute;top:2px;width:18px;height:18px;border-radius:50%;background:#fff;transition:left .25s;box-shadow:0 1px 4px rgba(0,0,0,.3)}
.tog.on .tth{left:20px}
.tog.off .tth{left:2px}
.branch-card{background:var(--s1);border:1px solid var(--bdr);border-radius:13px;padding:12px 14px;margin:0 22px 7px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:border-color .2s}
.branch-card:hover{border-color:var(--bdr2)}
.branch-card.act{border-color:rgba(123,92,255,.38);background:rgba(123,92,255,.04)}
.bc-ico{width:34px;height:34px;border-radius:9px;background:var(--s3);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.bc-ico svg{width:16px;height:16px;color:var(--p2)}
.bc-info{flex:1;min-width:0}
.bc-name{font-size:13px;font-weight:700;color:var(--txt)}
.bc-loc{font-size:11px;color:var(--t2);margin-top:1px}
.bc-meta{font-size:10px;color:var(--t3);margin-top:1px}
