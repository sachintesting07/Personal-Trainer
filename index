.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;padding:0 22px;margin-bottom:14px}
.stat-card{background:var(--s1);border:1px solid var(--bdr);border-radius:14px;padding:13px}
.stat-v{font-size:22px;font-weight:900;color:var(--txt);letter-spacing:-.5px;line-height:1}
.stat-l{font-size:10px;color:var(--t3);margin-top:3px;text-transform:uppercase;letter-spacing:.4px;font-weight:500}
