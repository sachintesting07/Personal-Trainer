.cred-row{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid rgba(32,200,120,.1)}
.cred-row:last-child{border-bottom:none}
.cred-k{font-size:11px;color:rgba(32,200,120,.5)}
.cred-v{font-size:11px;font-weight:700;color:var(--grn);font-family:monospace}

