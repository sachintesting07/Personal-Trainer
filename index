.fi::placeholder{color:#45455E}
.fi option{background:#12121F;color:#F0F0FA}
.f2{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.opt-g{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:5px}
.oo{padding:9px;border-radius:9px;border:1px solid var(--bdr2);background:var(--s2);text-align:center;font-size:12px;font-weight:500;color:#9090B8;cursor:pointer;transition:all .15s;font-family:'Inter',sans-serif}
.oo:hover{border-color:var(--p2);color:#C0B8FF}
.oo.on{border-color:var(--p);background:rgba(123,92,255,.13);color:#C0B8FF}
