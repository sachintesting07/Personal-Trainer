.rev-stat-v{font-size:16px;font-weight:800;color:#fff;letter-spacing:-.3px}
.rev-stat-l{font-size:10px;color:rgba(255,255,255,.35);margin-top:2px;text-transform:uppercase;letter-spacing:.4px}
.opp-card{background:var(--s1);border:1px solid var(--bdr);border-radius:13px;padding:12px 13px;margin-bottom:7px;display:flex;align-items:center;gap:11px}
