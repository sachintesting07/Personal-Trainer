.pb-price span{font-size:12px;color:rgba(255,255,255,.4);font-weight:400}
.pb-feats{display:flex;flex-direction:column;gap:5px;margin-top:11px}
.pb-feat{display:flex;align-items:center;gap:6px;font-size:11px;color:rgba(255,255,255,.55)}
