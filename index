}

function buildStepInd(){
  let h='<div class="step-ind">';
  STEP_LABELS.forEach((lbl,i)=>{
    const cls=i<enrollStep?'done':i===enrollStep?'act':'';
    const inner=i<enrollStep?`<svg viewBox="0 0 10 10" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:9px;height:9px"><polyline points="2,5 4,7.5 8,3"/></svg>`:i+1;
    h+=`<div class="si-node"><div class="si-c ${cls}">${inner}</div><div class="si-lbl ${cls==='act'?'act':''}">${lbl}</div></div>`;
    if(i<4) h+=`<div class="si-line ${i<enrollStep?'done':''}"></div>`;
  });
  return h+'</div>';
}

