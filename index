function renderEnrollStep(){
  document.getElementById('enroll-title').textContent=STEP_TITLES[enrollStep];
  const isLast=enrollStep===4;
  document.getElementById('enroll-body').innerHTML=buildStepInd()+ENROLL_STEPS[enrollStep]()+
    `<button class="btn-p" onclick="${isLast?'enrollDone()':'nextEnroll()'}">${isLast?'Enroll Member →':'Continue →'}</button>`+
    (enrollStep>0?`<button class="btn-g" onclick="prevEnroll()">← Back</button>`:'');
}

function saveEnrollFields(){
  const g=id=>{const e=document.getElementById(id);return e?e.value:undefined};
  if(enrollStep===0){enrollData.name=g('e-name');enrollData.email=g('e-email');enrollData.phone=g('e-phone');enrollData.branch=g('e-branch');}
  if(enrollStep===1){enrollData.age=g('e-age');enrollData.weight=g('e-weight');enrollData.health=g('e-health');}
  if(enrollStep===2){enrollData.targetWeight=g('e-target');enrollData.cuisine=g('e-cuisine');const s=document.getElementById('e-supp');enrollData.supp=s?s.checked:false;}
  if(enrollStep===3){enrollData.amount=g('e-amount');enrollData.startDate=g('e-start');}
}
function nextEnroll(){saveEnrollFields();if(enrollStep<4){enrollStep++;renderEnrollStep();document.getElementById('enroll-body').scrollTop=0;}}
function prevEnroll(){saveEnrollFields();if(enrollStep>0){enrollStep--;renderEnrollStep();document.getElementById('enroll-body').scrollTop=0;}}
function selOpt(el,gid,key){document.querySelectorAll('#'+gid+' .oo').forEach(o=>o.classList.remove('on'));el.classList.add('on');enrollData[key]=el.textContent.trim();}
function selPlan(el,name,val){document.querySelectorAll('#pg-plan .plan-o').forEach(o=>o.classList.remove('on'));el.classList.add('on');enrollData.plan=name;enrollData.planVal=val;const i=document.getElementById('e-amount');if(i)i.value=val;}
function enrollDone(){closeModal('enroll');showToast('Member enrolled successfully! 🎉');}

// ═══ MODALS ═══
function openModal(id){
  const ov=document.getElementById('modal-'+id);
  const mo=document.getElementById('inner-'+id);
  if(!ov||!mo) return;
  ov.classList.remove('hidden');
  setTimeout(()=>mo.classList.remove('hidden'),10);
}
function closeModal(id){
  const ov=document.getElementById('modal-'+id);
  const mo=document.getElementById('inner-'+id);
  if(!ov||!mo) return;
  mo.classList.add('hidden');
  setTimeout(()=>ov.classList.add('hidden'),320);
}

